# Copiar a .env y completar. NUNCA subir el .env real al repositorio.

# Token compartido: la PWA lo pide la primera vez que se abre
AUTH_TOKEN=

# Claves Web Push. Generar con: python scripts/generate_vapid.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=tu-correo@example.com

# Opcional: clave de https://twelvedata.com — si se define, reemplaza a Yahoo
TWELVE_DATA_KEY=

# Frecuencia del escaneo de cruces (minutos)
SCAN_INTERVAL_MIN=15

# true = solo escanear de lunes a viernes en horario de mercado (13-22 UTC)
SCAN_MARKET_HOURS_ONLY=false
